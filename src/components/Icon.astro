---
// Inline SVG icons resolved from src/data/icons.json (generated by
// scripts/build-icons.mjs). Generic glyphs come from Lucide (the lilAgents
// house standard, rendered as stroke); brand logos come from FontAwesome Free
// brands (rendered as fill), because Lucide ships no brand marks.
//
// The resolver is forgiving: it normalizes the freeform name from profile.json,
// maps common aliases to the canonical icon, and falls back to a link glyph for
// anything unknown, so a user can never pick an icon that fails to render.
import icons from "../data/icons.json";

interface Props {
  name?: string;
  class?: string;
}

const { name, class: className = "w-5 h-5" } = Astro.props;

const aliases: Record<string, string> = {
  twitter: "x-twitter",
  "twitter-x": "x-twitter",
  x: "x-twitter",
  "earth-americas": "globe",
  earth: "globe",
  website: "globe",
  web: "globe",
  envelope: "mail",
  email: "mail",
  shop: "store",
  shopping: "store",
  "shopping-cart": "store",
  cart: "store",
  blog: "rss",
  newsletter: "substack",
  calendar_days: "calendar-days",
  book: "book-open",
  booking: "calendar-days",
  call: "calendar-days",
  cal: "calendar-days",
  "cal.com": "calendar-days",
  "apple-music": "apple",
  applemusic: "apple",
  yt: "youtube",
  ig: "instagram",
  fb: "facebook",
  bsky: "bluesky",
};

const map = icons as Record<string, { mode: string; viewBox: string; body: string }>;
const key = (name ?? "").toLowerCase().trim();
const resolvedName = aliases[key] ?? key;
const icon = map[resolvedName] ?? map["link"];
const isStroke = icon.mode === "stroke";
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox={icon.viewBox}
  fill={isStroke ? "none" : "currentColor"}
  stroke={isStroke ? "currentColor" : undefined}
  stroke-width={isStroke ? 2 : undefined}
  stroke-linecap={isStroke ? "round" : undefined}
  stroke-linejoin={isStroke ? "round" : undefined}
  class={className}
  aria-hidden="true"
  set:html={icon.body}
></svg>
