---
import Icon from "./Icon.astro";

interface Props {
  title: string;
  subtitle?: string;
  url: string;
  icon?: string;
}

const { title, subtitle, url, icon } = Astro.props;
---

<a
  href={url}
  target="_blank"
  class="group flex items-center justify-between p-4 rounded-lg bg-card text-card-foreground w-full hover:bg-accent/5 dark:hover:bg-accent/10 transition-all duration-200 ease-in-out border border-border/50 transform hover:-translate-y-0.5 hover:shadow-md"
>
  <div class="flex items-start">
    <div class="flex items-center self-center mr-3">
      <span class="text-primary">
        <Icon name={icon} class="w-5 h-5" />
      </span>
    </div>

    <div class="flex flex-col">
      <span class="font-medium">{title}</span>
      {
        subtitle && (
          <span class="text-xs text-muted-foreground mt-0.5">{subtitle}</span>
        )
      }
    </div>
  </div>

  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="24"
    height="24"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="h-5 w-5 text-muted-foreground group-hover:text-primary transition-colors"
    aria-hidden="true"
  >
    <path d="m9 18 6-6-6-6"></path>
  </svg>
</a>
