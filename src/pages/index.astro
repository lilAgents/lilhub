---
import Layout from "../layouts/Layout.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import LinkCard from "../components/LinkCard.astro";
import Footer from "../components/Footer.astro";
import profile from "../content/profile.json";

// This is the linktree itself: the page each lilHub owner publishes. It reads
// the single source of truth (src/content/profile.json, edited at /admin) and
// renders the avatar, name, bio, and link cards. The brand color in
// profile.theme.primary drives the whole palette via Layout's injectTheme.

interface Link {
  title: string;
  subtitle?: string;
  url: string;
  icon?: string;
}

const name = (profile.name || "Your Name").trim();
const description = (profile.description || "").trim();
const avatar = profile.avatar || "/uploads/avatar-placeholder.svg";
const showAttribution = profile.showAttribution !== false;
const links = (profile.links ?? []).filter((l: Link) => l && l.url) as Link[];

// SEO title + description. Default the title to "Name | lilHub" and the
// description to the owner's bio, but let either be overridden from /admin
// (the Meta Title / Meta Description fields) when they want full control.
const metaTitle =
  ((profile as { metaTitle?: string }).metaTitle || "").trim() ||
  `${name} | lilHub`;
const metaDescription =
  ((profile as { metaDescription?: string }).metaDescription || "").trim() ||
  description ||
  `${name} on lilHub`;
---

<Layout title={metaTitle} description={metaDescription} ogImage="/og.png">
  <div
    class="min-h-screen flex flex-col items-center justify-center py-8 px-4 bg-background text-foreground"
  >
    <ThemeToggle />

    <main class="w-full max-w-md mx-auto flex flex-col items-center">
      <header class="flex flex-col items-center">
        <img
          src={avatar}
          alt={`${name} profile photo`}
          class="w-20 h-20 object-cover rounded-full mb-4"
          width="80"
          height="80"
        />

        <h1 class="text-2xl font-semibold text-foreground mb-1">{name}</h1>

        {
          description && (
            <p class="text-sm text-center text-muted-foreground max-w-xs mb-4">
              {description}
            </p>
          )
        }
      </header>

      <div class="w-full space-y-3 mt-2">
        {
          links.map((link) => (
            <LinkCard
              title={link.title}
              subtitle={link.subtitle}
              url={link.url}
              icon={link.icon}
            />
          ))
        }
      </div>

      <!--
        Owner shortcut into the editor: opens this profile directly in Sveltia.
        It shows on the public page, but only the owner can sign in with GitHub,
        so it is harmless for visitors.
      -->
      <a
        href="/admin/#/collections/profile/entries/profile"
        class="inline-flex items-center gap-2 mt-8 px-4 py-2 rounded-lg border border-border text-sm text-muted-foreground transition-colors hover:text-foreground hover:border-foreground/40"
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M12 20h9"></path>
          <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
        </svg>
        Edit this page
      </a>
    </main>

    <Footer show={showAttribution} />
  </div>
</Layout>
