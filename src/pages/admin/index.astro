---
// Sveltia CMS admin shell. This page is the editor for your lilHub: it loads
// Sveltia from the unpkg CDN and reads its collection config from
// /admin/config.yml (in public/). Saves write back to src/content/profile.json
// in your repo through the GitHub backend (authenticated via the shared
// lilAgents auth broker), or directly to disk in local development.
//
// Rendered as a standalone HTML page (no site Layout) because Sveltia owns the
// whole document. Marked noindex so the editor never shows up in search.
export const prerender = true;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <!--
      Content-Security-Policy for the admin shell. Sveltia is loaded from unpkg
      and talks to the GitHub API and the lilAgents auth broker, so those origins
      are allowlisted here. Uploaded media and avatars can be any https image.
    -->
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com; style-src 'self' 'unsafe-inline' https://unpkg.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://unpkg.com https://api.github.com https://lilhub-auth.lilagents.workers.dev; frame-src https://lilhub-auth.lilagents.workers.dev;"
    />
    <title>Content Manager</title>
  </head>
  <body>
    <script src="https://unpkg.com/@sveltia/cms/dist/sveltia-cms.js"></script>
  </body>
</html>
