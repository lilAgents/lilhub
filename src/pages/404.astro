---
import Layout from "../layouts/Layout.astro";
import ThemeToggle from "../components/ThemeToggle.astro";

// Custom 404 so unmatched routes get an on-brand page instead of Netlify's
// generic default. Astro emits this to /404.html, which Netlify serves
// automatically for not-found requests.
---

<Layout
  title="Page not found"
  description="That page could not be found."
  noIndex={true}
>
  <main
    class="min-h-screen flex flex-col items-center justify-center text-center bg-background text-foreground px-6"
  >
    <ThemeToggle />
    <p class="text-6xl sm:text-7xl font-semibold text-primary mb-4">404</p>
    <h1 class="text-2xl sm:text-3xl font-semibold mb-3">Page not found</h1>
    <p class="text-base text-muted-foreground max-w-md mb-8">
      The link might be off, or this page is no longer here.
    </p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a
        href="/"
        class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-primary text-primary-foreground font-medium hover:opacity-90 transition"
        >Back home</a
      >
    </div>
  </main>
</Layout>
